# CODEOWNERS
#
# This file maps repository paths to responsible owners.
# GitHub uses this file to automatically request reviews from the appropriate
# owners when a pull request modifies files they own.
#
# Format: path  @owner-or-team
# See: https://docs.github.com/en/repositories/managing-your-repositorys-settings-and-features/customizing-your-repository/about-code-owners

# Default owner for everything in the repository
*                               @platform-team

# Standards source registry — requires review of any new standard registration
01-sources/                     @platform-team

# Platform taxonomy — vocabulary changes affect every other domain
02-taxonomy/                    @platform-team

# Control catalog — changes to controls affect all governed repositories
03-catalogs/                    @platform-team

# Compliance profiles — gate criteria changes affect all consuming repositories
04-profiles/                    @platform-team

# Mapping records — provenance chain integrity
05-mappings/                    @platform-team

# Implementation bindings — specification layer for policy authors
06-bindings/                    @platform-team

# Policy-as-code — executable compliance rules
07-policies/                    @platform-team

# Evidence system — immutable record infrastructure
08-evidence/                    @platform-team

# Assessment system — gate criteria and waiver governance
09-assessments/                 @platform-team

# Schemas — contract definitions used by all tooling
schemas/                        @platform-team

# Architecture decisions — immutable once accepted
decisions/                      @platform-team

# Workflows — CI/CD pipeline definitions consumed by downstream repos
.github/                        @platform-team
workflows/                      @platform-team
